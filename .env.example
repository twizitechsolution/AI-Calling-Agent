# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy this file to .env and fill in your real values.
# Stack: LiveKit + Deepgram STT + OpenAI LLM + ElevenLabs TTS + Silero VAD
# ══════════════════════════════════════════════════════════════════════════════
# ⚠️  NEVER commit .env to git. This example file is safe to commit.
# ══════════════════════════════════════════════════════════════════════════════

# ── LiveKit Cloud ────────────────────────────────────────────────────────────
# Get from: https://cloud.livekit.io/ → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── OpenAI (LLM — Primary) ───────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# ── Deepgram (STT — Primary) ─────────────────────────────────────────────────
# Get from: https://console.deepgram.com/
# Model: Nova-2 General | Streaming | Multilingual auto-detect
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── ElevenLabs (TTS — Primary) ───────────────────────────────────────────────
# Get from: https://elevenlabs.io/app/settings/api-keys
# Model: eleven_turbo_v2_5 (lowest latency, streaming)
# Voice IDs: Browse at https://elevenlabs.io/voice-library
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── GroqAI (LLM — optional fallback) ─────────────────────────────────────────
# Set llm_provider=groq in config.json to activate
GROQ_API_KEY=your_groq_api_key

# ── Sarvam AI (STT + TTS — legacy fallback) ───────────────────────────────────
# Set stt_provider=sarvam or tts_provider=sarvam in config.json to activate
SARVAM_API_KEY=your_sarvam_api_key

# ── Cal.com (Appointment Booking) ────────────────────────────────────────────
# Get from: https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=your_cal_api_key
CAL_EVENT_TYPE_ID=your_event_type_id

# ── Supabase (Database + Call Logs) ──────────────────────────────────────────
# Get from: https://app.supabase.com/ → project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── Supabase S3 (Call Recordings) ────────────────────────────────────────────
# Get from: Supabase Dashboard → Storage → Settings → S3 credentials
SUPABASE_S3_ACCESS_KEY=your_s3_access_key
SUPABASE_S3_SECRET_KEY=your_s3_secret_key
SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-south-1

# ── Telegram Notifications ────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── SIP / TVOBIZ (Inbound Phone Calls) ───────────────────────────────────────
# Get from: https://app.vobiz.ai/ → SIP Trunks
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# ── Call Transfer (Human Agent Fallback) ─────────────────────────────────────
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# ── Cost Protection ───────────────────────────────────────────────────────────
# Maximum call duration in seconds before graceful wrap-up and hangup.
# Prevents runaway costs from stuck/looping calls.
# 600 = 10 minutes (recommended default for sales calls)
MAX_CALL_DURATION_SECONDS=600

# ── Optional: n8n Webhook (CRM / Automation) ─────────────────────────────────
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/call-completed

# ── Optional: Sentry (Error Tracking) ────────────────────────────────────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# ENVIRONMENT=production
